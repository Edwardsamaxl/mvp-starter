{
  "name": "mvp-starter",
  "version": "1.0.0",
  "description": "Lightweight MVP framework for rapid prototyping",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node --watch src/server/server.js",
    "dev:client": "vite",
    "build": "vite build",
    "start": "node src/server/server.js",
    "lint": "eslint src --fix",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "express": "^5.2.1",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.5.0",
    "concurrently": "^9.1.0",
    "vite": "^6.3.0",
    "vitest": "^3.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  }
}
