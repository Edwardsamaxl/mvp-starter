# Server Configuration
PORT=3000
NODE_ENV=development

# CORS
CORS_ORIGIN=http://localhost:5173

# Session (REQUIRED in production - generate a secure random string)
SESSION_SECRET=your-secure-secret-here

# Database (optional - only if plugins.database is enabled)
# DB_CONNECTION_STRING=mongodb://localhost:27017/mydb
# DB_CONNECTION_STRING=postgresql://user:password@localhost:5432/mydb
